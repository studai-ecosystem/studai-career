# AI Configuration - Azure OpenAI (Primary)
# NOTE: These are REQUIRED. There is no hardcoded fallback in the code anymore.
AI_PRIMARY_PROVIDER=azure
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_ID=gpt-5.4
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_MODEL=gpt-5.4
AZURE_OPENAI_MODEL_MINI=gpt-5.4

# AI Configuration - Azure Anthropic (Fallback)
AI_FALLBACK_PROVIDER=anthropic
AZURE_ANTHROPIC_ENDPOINT=https://your-resource.services.ai.azure.com/anthropic/
AZURE_ANTHROPIC_API_KEY=your-azure-anthropic-api-key
AZURE_ANTHROPIC_MODEL=claude-sonnet-4-5

# AI Settings
AI_MAX_TOKENS=16384
AI_TEMPERATURE=0.7
AI_CACHE_ENABLED=true
AI_REQUEST_TIMEOUT=60

# Search Configuration
